@page "/gestion-profesoral-tablas"
@rendermode InteractiveServer
@using FrontBlazor_AppiGenericaCsharp.Services
@inject ApiService Api

<PageTitle>Tablas Gestión Profesoral</PageTitle>

<h1>Tablas de Gestión Profesoral (CRUD directo)</h1>
<p class="text-muted">CRUD explícito para tablas de detalle con selects de claves foráneas.</p>

<GenericCrud Title="Estudios Realizados" TableName="estudios_realizados" Fields="estudiosFields" KeyFields="estudiosKeys" LookupByField="estudiosLookups" />
<GenericCrud Title="Evaluación Docente" TableName="evaluacion_docente" Fields="evaluacionFields" KeyFields="evaluacionKeys" LookupByField="evaluacionLookups" />
<GenericCrud Title="Experiencia" TableName="experiencia" Fields="experienciaFields" KeyFields="experienciaKeys" LookupByField="experienciaLookups" />
<GenericCrud Title="Reconocimiento" TableName="reconocimiento" Fields="reconocimientoFields" KeyFields="reconocimientoKeys" LookupByField="reconocimientoLookups" />
<GenericCrud Title="Docente Departamento" TableName="docente_departamento" Fields="docenteDepartamentoFields" KeyFields="docenteDepartamentoKeys" LookupByField="docenteDepartamentoLookups" />
<GenericCrud Title="Alianza" TableName="alianza" Fields="alianzaFields" KeyFields="alianzaKeys" LookupByField="alianzaLookups" />
<GenericCrud Title="Beca" TableName="beca" Fields="becaFields" KeyFields="becaKeys" LookupByField="becaLookups" />
<GenericCrud Title="Apoyo Profesoral" TableName="apoyo_profesoral" Fields="apoyoFields" KeyFields="apoyoKeys" LookupByField="apoyoLookups" />
<GenericCrud Title="Estudio AC" TableName="estudio_ac" Fields="estudioAcFields" KeyFields="estudioAcKeys" LookupByField="estudioAcLookups" />
<GenericCrud Title="Intereses Futuros" TableName="intereses_futuros" Fields="interesesFuturosFields" KeyFields="interesesFuturosKeys" LookupByField="interesesFuturosLookups" />

@code {
    private readonly List<string> estudiosKeys = ["id"];
    private readonly List<string> evaluacionKeys = ["id"];
    private readonly List<string> experienciaKeys = ["id"];
    private readonly List<string> reconocimientoKeys = ["id"];
    private readonly List<string> docenteDepartamentoKeys = ["docente", "departamento"];
    private readonly List<string> alianzaKeys = ["aliado", "departamento"];
    private readonly List<string> becaKeys = ["estudios"];
    private readonly List<string> apoyoKeys = ["estudios"];
    private readonly List<string> estudioAcKeys = ["estudio", "area_conocimiento"];
    private readonly List<string> interesesFuturosKeys = ["docente", "termino_clave"];

    private readonly List<CrudFieldDefinition> estudiosFields =
    [
        new() { Name = "id", Label = "Id", Type = FieldType.Integer, Required = true },
        new() { Name = "titulo", Label = "Título", Required = true },
        new() { Name = "universidad", Label = "Universidad", Required = true },
        new() { Name = "fecha", Label = "Fecha", Type = FieldType.Date, Required = true },
        new() { Name = "tipo", Label = "Tipo", Required = true },
        new() { Name = "ciudad", Label = "Ciudad", Required = true },
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "ins_acreditada", Label = "Acreditada", Type = FieldType.Boolean, Required = true },
        new() { Name = "metodologia", Label = "Metodología", Required = true },
        new() { Name = "perfil_egresado", Label = "Perfil egresado", Required = true, Multiline = true },
        new() { Name = "pais", Label = "País", Required = true }
    ];

    private readonly List<CrudFieldDefinition> evaluacionFields =
    [
        new() { Name = "calificacion", Label = "Calificación", Type = FieldType.Decimal, Required = true },
        new() { Name = "semestre", Label = "Semestre", Required = true },
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true }
    ];

    private readonly List<CrudFieldDefinition> experienciaFields =
    [
        new() { Name = "nombre_cargo", Label = "Cargo", Required = true },
        new() { Name = "institucion", Label = "Institución", Required = true },
        new() { Name = "tipo", Label = "Tipo", Required = true },
        new() { Name = "fecha_inicio", Label = "Fecha inicio", Type = FieldType.Date, Required = true },
        new() { Name = "fecha_fin", Label = "Fecha fin", Type = FieldType.Date },
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true }
    ];

    private readonly List<CrudFieldDefinition> reconocimientoFields =
    [
        new() { Name = "tipo", Label = "Tipo", Required = true },
        new() { Name = "fecha", Label = "Fecha", Type = FieldType.Date, Required = true },
        new() { Name = "institucion", Label = "Institución", Required = true },
        new() { Name = "nombre", Label = "Nombre", Required = true },
        new() { Name = "ambito", Label = "Ámbito", Required = true },
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true }
    ];

    private readonly List<CrudFieldDefinition> docenteDepartamentoFields =
    [
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "departamento", Label = "Departamento", Type = FieldType.Integer, Required = true },
        new() { Name = "dedicacion", Label = "Dedicación", Required = true },
        new() { Name = "modalidad", Label = "Modalidad", Required = true },
        new() { Name = "fecha_ingreso", Label = "Fecha ingreso", Type = FieldType.Date, Required = true },
        new() { Name = "fecha_salida", Label = "Fecha salida", Type = FieldType.Date }
    ];

    private readonly List<CrudFieldDefinition> alianzaFields =
    [
        new() { Name = "aliado", Label = "Aliado", Type = FieldType.Long, IsForeignKey = true, Required = true },
        new() { Name = "departamento", Label = "Departamento", Type = FieldType.Integer, Required = true },
        new() { Name = "fecha_inicio", Label = "Fecha inicio", Type = FieldType.Date, Required = true },
        new() { Name = "fecha_fin", Label = "Fecha fin", Type = FieldType.Date },
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true }
    ];

    private readonly List<CrudFieldDefinition> becaFields =
    [
        new() { Name = "estudios", Label = "Estudio", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "tipo", Label = "Tipo", Required = true },
        new() { Name = "institucion", Label = "Institución", Required = true },
        new() { Name = "fecha_inicio", Label = "Fecha inicio", Type = FieldType.Date, Required = true },
        new() { Name = "fecha_fin", Label = "Fecha fin", Type = FieldType.Date }
    ];

    private readonly List<CrudFieldDefinition> apoyoFields =
    [
        new() { Name = "estudios", Label = "Estudio", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "con_apoyo", Label = "Con apoyo", Type = FieldType.Boolean, Required = true },
        new() { Name = "institucion", Label = "Institución", Required = true },
        new() { Name = "tipo", Label = "Tipo", Required = true }
    ];

    private readonly List<CrudFieldDefinition> estudioAcFields =
    [
        new() { Name = "estudio", Label = "Estudio", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "area_conocimiento", Label = "Área conocimiento", Type = FieldType.Integer, IsForeignKey = true, Required = true }
    ];

    private readonly List<CrudFieldDefinition> interesesFuturosFields =
    [
        new() { Name = "docente", Label = "Docente", Type = FieldType.Integer, IsForeignKey = true, Required = true },
        new() { Name = "termino_clave", Label = "Término", IsForeignKey = true, Required = true }
    ];

    private Dictionary<string, List<LookupOption>> estudiosLookups = new();
    private Dictionary<string, List<LookupOption>> evaluacionLookups = new();
    private Dictionary<string, List<LookupOption>> experienciaLookups = new();
    private Dictionary<string, List<LookupOption>> reconocimientoLookups = new();
    private Dictionary<string, List<LookupOption>> docenteDepartamentoLookups = new();
    private Dictionary<string, List<LookupOption>> alianzaLookups = new();
    private Dictionary<string, List<LookupOption>> becaLookups = new();
    private Dictionary<string, List<LookupOption>> apoyoLookups = new();
    private Dictionary<string, List<LookupOption>> estudioAcLookups = new();
    private Dictionary<string, List<LookupOption>> interesesFuturosLookups = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarLookupsAsync();
    }

    private async Task CargarLookupsAsync()
    {
        var docentes = await Api.ListarAsync("docente");
        var estudios = await Api.ListarAsync("estudios_realizados");
        var aliados = await Api.ListarAsync("aliado");
        var areas = await Api.ListarAsync("area_conocimiento");
        var terminos = await Api.ListarAsync("termino_clave");

        var docentesOptions = MapOptions(docentes, "cedula", "nombres");
        var estudiosOptions = MapOptions(estudios, "id", "titulo");
        var aliadosOptions = MapOptions(aliados, "nit", "razon_social");
        var areasOptions = MapOptions(areas, "id", "area");
        var terminosOptions = MapOptions(terminos, "termino", "termino");

        estudiosLookups = new() { ["docente"] = docentesOptions };
        evaluacionLookups = new() { ["docente"] = docentesOptions };
        experienciaLookups = new() { ["docente"] = docentesOptions };
        reconocimientoLookups = new() { ["docente"] = docentesOptions };
        docenteDepartamentoLookups = new() { ["docente"] = docentesOptions };
        alianzaLookups = new() { ["aliado"] = aliadosOptions, ["docente"] = docentesOptions };
        becaLookups = new() { ["estudios"] = estudiosOptions };
        apoyoLookups = new() { ["estudios"] = estudiosOptions };
        estudioAcLookups = new() { ["estudio"] = estudiosOptions, ["area_conocimiento"] = areasOptions };
        interesesFuturosLookups = new() { ["docente"] = docentesOptions, ["termino_clave"] = terminosOptions };
    }

    private static List<LookupOption> MapOptions(List<Dictionary<string, object?>> data, string keyField, string textField)
    {
        return data
            .Select(row => new LookupOption
            {
                Value = row.TryGetValue(keyField, out var key) ? key?.ToString() ?? string.Empty : string.Empty,
                Text = row.TryGetValue(textField, out var text) ? text?.ToString() ?? string.Empty : string.Empty
            })
            .Where(x => !string.IsNullOrWhiteSpace(x.Value))
            .ToList();
    }
}
