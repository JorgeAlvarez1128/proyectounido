@page "/aliado"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>CRUD Aliado</PageTitle>

<h1>CRUD de Aliado</h1>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(esError ? "alert-danger" : "alert-success")" role="alert">
        @mensaje
    </div>
}

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-header">@((editando) ? "Editar aliado" : "Crear aliado")</div>
            <div class="card-body">
                <EditForm Model="form" OnValidSubmit="GuardarAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="mb-3">
                        <label class="form-label" for="nit">NIT</label>
                        <InputNumber id="nit" class="form-control" @bind-Value="form.Nit" disabled="@editando" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="razonSocial">Razón social</label>
                        <InputText id="razonSocial" class="form-control" @bind-Value="form.RazonSocial" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="nombreContacto">Nombre contacto</label>
                        <InputText id="nombreContacto" class="form-control" @bind-Value="form.NombreContacto" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="correo">Correo</label>
                        <InputText id="correo" class="form-control" @bind-Value="form.Correo" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="telefono">Teléfono</label>
                        <InputText id="telefono" class="form-control" @bind-Value="form.Telefono" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="ciudad">Ciudad</label>
                        <InputText id="ciudad" class="form-control" @bind-Value="form.Ciudad" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(editando ? "Actualizar" : "Crear")</button>
                        <button type="button" class="btn btn-secondary" @onclick="LimpiarFormulario">Limpiar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Listado de aliados</span>
                <button class="btn btn-outline-primary btn-sm" @onclick="CargarAsync">Recargar</button>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>NIT</th>
                            <th>Razón social</th>
                            <th>Nombre contacto</th>
                            <th>Correo</th>
                            <th>Teléfono</th>
                            <th>Ciudad</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (aliados.Count == 0)
                        {
                            <tr><td colspan="7">No hay datos.</td></tr>
                        }
                        else
                        {
                            @foreach (var aliado in aliados)
                            {
                                <tr>
                                    <td>@aliado.Nit</td>
                                    <td>@aliado.RazonSocial</td>
                                    <td>@aliado.NombreContacto</td>
                                    <td>@aliado.Correo</td>
                                    <td>@aliado.Telefono</td>
                                    <td>@aliado.Ciudad</td>
                                    <td class="d-flex gap-2">
                                        <button class="btn btn-sm btn-warning" @onclick="() => Editar(aliado)">Editar</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarAsync(aliado.Nit)">Eliminar</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private const string Tabla = "aliado";

    private List<AliadoModel> aliados = new();
    private AliadoModel form = new();
    private bool editando;
    private string mensaje = string.Empty;
    private bool esError;

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        var datos = await Api.ListarAsync(Tabla);

        aliados = datos.Select(d => new AliadoModel
        {
            Nit = ObtenerLong(d, "nit"),
            RazonSocial = ObtenerTexto(d, "razon_social"),
            NombreContacto = ObtenerTexto(d, "nombre_contacto"),
            Correo = ObtenerTexto(d, "correo"),
            Telefono = ObtenerTexto(d, "telefono"),
            Ciudad = ObtenerTexto(d, "ciudad")
        }).ToList();
    }

    private async Task GuardarAsync()
    {
        Dictionary<string, object?> payload = new()
        {
            ["nit"] = form.Nit,
            ["razon_social"] = form.RazonSocial,
            ["nombre_contacto"] = form.NombreContacto,
            ["correo"] = form.Correo,
            ["telefono"] = form.Telefono,
            ["ciudad"] = form.Ciudad
        };

        (bool exito, string mensaje) resultado;

        if (editando)
        {
            resultado = await Api.ActualizarAsync(Tabla, "nit", form.Nit.ToString(), payload);
        }
        else
        {
            resultado = await Api.CrearAsync(Tabla, payload);
        }

        mensaje = resultado.mensaje;
        esError = !resultado.exito;

        if (resultado.exito)
        {
            LimpiarFormulario();
            await CargarAsync();
        }
    }

    private void Editar(AliadoModel aliado)
    {
        form = new AliadoModel
        {
            Nit = aliado.Nit,
            RazonSocial = aliado.RazonSocial,
            NombreContacto = aliado.NombreContacto,
            Correo = aliado.Correo,
            Telefono = aliado.Telefono,
            Ciudad = aliado.Ciudad
        };
        editando = true;
        mensaje = string.Empty;
    }

    private async Task EliminarAsync(long nit)
    {
        var resultado = await Api.EliminarAsync(Tabla, "nit", nit.ToString());

        if (!resultado.exito)
        {
            var intentoAlterno = await Api.EliminarAsync(Tabla, "id", nit.ToString());
            if (intentoAlterno.exito)
            {
                resultado = intentoAlterno;
            }
        }

        mensaje = resultado.mensaje;
        esError = !resultado.exito;

        if (resultado.exito)
        {
            if (editando && form.Nit == nit)
            {
                LimpiarFormulario();
            }

            await CargarAsync();
        }
    }

    private void LimpiarFormulario()
    {
        form = new AliadoModel();
        editando = false;
    }

    private static long ObtenerLong(Dictionary<string, object?> dic, string clave)
    {
        if (!dic.TryGetValue(clave, out var valor) || valor is null)
        {
            return 0;
        }

        return valor switch
        {
            long l => l,
            int i => i,
            double d => (long)d,
            decimal m => (long)m,
            _ => long.TryParse(valor.ToString(), out var n) ? n : 0
        };
    }

    private static string ObtenerTexto(Dictionary<string, object?> dic, string clave)
    {
        return dic.TryGetValue(clave, out var valor) && valor is not null
            ? valor.ToString() ?? string.Empty
            : string.Empty;
    }

    private sealed class AliadoModel
    {
        public long Nit { get; set; }
        public string RazonSocial { get; set; } = string.Empty;
        public string NombreContacto { get; set; } = string.Empty;
        public string Correo { get; set; } = string.Empty;
        public string Telefono { get; set; } = string.Empty;
        public string Ciudad { get; set; } = string.Empty;
    }
}
