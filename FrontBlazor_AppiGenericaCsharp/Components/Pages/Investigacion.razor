@page "/investigacion"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>CRUD Investigación</PageTitle>

<h1>CRUD de Investigación</h1>
<p class="text-muted">Gestiona registros de <code>linea_investigacion</code>.</p>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(esError ? "alert-danger" : "alert-success")" role="alert">
        @mensaje
    </div>
}

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <div class="card">
            <div class="card-header">@((editando) ? "Editar línea" : "Crear línea")</div>
            <div class="card-body">
                <EditForm Model="form" OnValidSubmit="GuardarAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    @if (editando)
                    {
                        <div class="mb-3">
                            <label class="form-label">Id</label>
                            <input class="form-control" value="@form.Id" disabled />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label" for="nombre">Nombre</label>
                        <InputText id="nombre" class="form-control" @bind-Value="form.Nombre" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label" for="descripcion">Descripción</label>
                        <InputTextArea id="descripcion" class="form-control" @bind-Value="form.Descripcion" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">@(editando ? "Actualizar" : "Crear")</button>
                        <button type="button" class="btn btn-secondary" @onclick="LimpiarFormulario">Limpiar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-7">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Listado de líneas</span>
                <button class="btn btn-outline-primary btn-sm" @onclick="CargarAsync">Recargar</button>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-striped table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (lineas.Count == 0)
                        {
                            <tr><td colspan="4">No hay datos.</td></tr>
                        }
                        else
                        {
                            @foreach (var linea in lineas)
                            {
                                <tr>
                                    <td>@linea.Id</td>
                                    <td>@linea.Nombre</td>
                                    <td>@linea.Descripcion</td>
                                    <td class="d-flex gap-2">
                                        <button class="btn btn-sm btn-warning" @onclick="() => Editar(linea)">Editar</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarAsync(linea.Id)">Eliminar</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private const string Tabla = "linea_investigacion";

    private List<InvestigacionModel> lineas = new();
    private InvestigacionModel form = new();
    private bool editando;
    private string mensaje = string.Empty;
    private bool esError;

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        var datos = await Api.ListarAsync(Tabla);

        lineas = datos.Select(d => new InvestigacionModel
        {
            Id = ObtenerEntero(d, "id"),
            Nombre = ObtenerTexto(d, "nombre"),
            Descripcion = ObtenerTexto(d, "descripcion")
        }).ToList();
    }

    private async Task GuardarAsync()
    {
        Dictionary<string, object?> payload = new()
        {
            ["nombre"] = form.Nombre,
            ["descripcion"] = form.Descripcion
        };

        (bool exito, string mensaje) resultado;

        if (editando)
        {
            resultado = await Api.ActualizarAsync(Tabla, "id", form.Id.ToString(), payload);
        }
        else
        {
            resultado = await Api.CrearAsync(Tabla, payload);
        }

        mensaje = resultado.mensaje;
        esError = !resultado.exito;

        if (resultado.exito)
        {
            LimpiarFormulario();
            await CargarAsync();
        }
    }

    private void Editar(InvestigacionModel linea)
    {
        form = new InvestigacionModel
        {
            Id = linea.Id,
            Nombre = linea.Nombre,
            Descripcion = linea.Descripcion
        };
        editando = true;
        mensaje = string.Empty;
    }

    private async Task EliminarAsync(int id)
    {
        var resultado = await Api.EliminarAsync(Tabla, "id", id.ToString());
        mensaje = resultado.mensaje;
        esError = !resultado.exito;

        if (resultado.exito)
        {
            if (editando && form.Id == id)
            {
                LimpiarFormulario();
            }

            await CargarAsync();
        }
    }

    private void LimpiarFormulario()
    {
        form = new InvestigacionModel();
        editando = false;
    }

    private static int ObtenerEntero(Dictionary<string, object?> dic, string clave)
    {
        if (!dic.TryGetValue(clave, out var valor) || valor is null)
        {
            return 0;
        }

        return valor switch
        {
            int i => i,
            long l => (int)l,
            double d => (int)d,
            decimal m => (int)m,
            _ => int.TryParse(valor.ToString(), out var n) ? n : 0
        };
    }

    private static string ObtenerTexto(Dictionary<string, object?> dic, string clave)
    {
        return dic.TryGetValue(clave, out var valor) && valor is not null
            ? valor.ToString() ?? string.Empty
            : string.Empty;
    }

    private sealed class InvestigacionModel
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
    }
}
